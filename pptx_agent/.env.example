HOST=127.0.0.1
PORT=8787

# Optional LLM. Leave empty to use the built-in deterministic planner.
# Any OpenAI-compatible /chat/completions endpoint works.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=

# Optional web search. SearXNG is local-first by default.
# Supported: auto, searxng, brave, serper, tavily, duckduckgo, none
SEARCH_PROVIDER=auto
# Can be one URL or a comma-separated fallback list.
SEARXNG_URL=http://127.0.0.1:8888,http://127.0.0.1:8080
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
MAX_SEARCH_RESULTS=6
